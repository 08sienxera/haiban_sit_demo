<% content_for(:head){ %>
<%= stylesheet_link_tag 'operator_vacation' %>
<style type="text/css"><!--
.grid-box {
    grid-template-columns: repeat(2, 1fr 1fr 3fr);
}

--></style>
<%= javascript_tag do %>
<% end %>
<% } %>

<div id="field1">
    <%= render :partial => "error_message" , :locals=>{:message_obj=>flash[:msg],:style_class=>'err'} %>
    <%= render :partial => "t_month_box",:locals=>{:day_info=>@t_tarm,:today=>Date.today(),:tbl_class=>"",:day_title=>""} %>
    <!-- カレンダー -->
    <div class="grid-box">
            <%
                cmn_style_class = ['grid-item']
                def_style_class = ['cmonth','nmonth']
                start_pos = [1,4]
                hist_index = [:last,:this]
            %>
            <%= content_tag(:div, "#{@tarm[:last][:month]}月度（前月）",:class=>"grid-item head-crt",:style=>"grid-row: 1 / 2;grid-column: 1/4;") %>
            <%= content_tag(:div, "#{@tarm[:current][:month]}月度（当月）",:class=>"grid-item head-crt",:style=>"grid-row: 1 / 2;grid-column: 4/7;") %>

            <% @tarm.values_at(:last,:current).each.with_index do |tarm,index| %>
            <% order_hist = @order_history[hist_index[index]]; column_pos = start_pos[index] %>
            <% (tarm[:length][:begin_date]..tarm[:length][:end_date]).each.with_index do |day,index| %>
                <% 
                day_str = day.day.to_s
                wday_str = I18n.t("date.abbr_day_names")[day.wday]
                wk_date = day.strftime("%Y%m%d")
                font_color = @wh[day].to_i==0 ? "black" : "red"
                # clazz = cmn_style_class + [def_style_class[loop_num]]
                clazz = cmn_style_class + ['cmonth']
                %>
                <%= content_tag(
                    :div, 
                    ["1","16"].include?(day_str) ? "#{day.month.to_s}/#{day_str}" : day_str,
                    :id=>"wk_date_#{wk_date}",
                    :class=>(clazz + ['day']).join(" "), 
                    :style=>"color:#{font_color};grid-row:#{index+2} / #{index+3};grid-column: #{column_pos+0} / #{column_pos+1};"
                ) %>
                <%= content_tag(
                    :div,
                    wday_str, 
                    :class=>(clazz + ['day']).join(" "), 
                    :style=>"color:#{font_color};grid-row:#{index+2} / #{index+3};grid-column: #{column_pos+1} / #{column_pos+2};"
                ) %>
                <%
                wkdate_order = order_hist.find{|order| order[:order_date]==day}
                if wkdate_order.present?
                    location_id = wkdate_order[:lunch_location_id]
                    menu_id = wkdate_order[:lunch_menu_id]
                    # menu_id = wkdate_order[:lunch_menu_id]
                end
                %>
                <%= content_tag(
                    :div,
                    "#{@location.find{|l| location_id.to_i==l[1].to_i}[0]}　#{@lunch_menu.find{|m| menu_id.to_i==m[1].to_i}[0]}", 
                    :id=> "order_#{wk_date}",
                    :class=>(clazz<<"order").join(" "), 
                    :style=>"grid-row:#{index+2} / #{index+3};grid-column:  #{column_pos+2} / #{column_pos+3};"
                ) %>
            <% end %>


            <% end %>
    </div>
    <!-- カレンダー（ここまで） -->


    <%= render :partial => "operator/back_to_top" %>
</div>

