<% content_for(:head) do %>
    <style type="text/css"><!--
        table {width:800px; margin:0 auto;}
        table,table th,table td {border-collapse: collapse; padding:10px;}
        table tr {border-bottom: solid 1px #eee;}
        table th {width:35%;}
        .container {
            margin: 30px 10px;
            border-radius: 5px;
            padding: 10px;
        }
        .container * {
            font-family:'メイリオ',Meiryo,'Hiragino Kaku Gothic Pro','ＭＳ Ｐゴシック',sans-serif;
            box-sizing: border-box;
            font-size:16px;
            color:#333;
            font-weight:normal;
        }
        .container a { text-decoration: none; display: inline-block; }
        .btn {
            padding:10px 40px;
            margin: 40px auto;
            display: block;
        }
    --></style>
    <%= javascript_tag do %>
        const doUpdate = ()=>{
            let form = document.getElementById('inform');
            form.submit();
        };
        const doDestroy = ()=>{
            let form = document.getElementById('delform');
            if(confirm("コメントを削除しますか？")){
                form.submit();
            }
        };
    <% end %>
<% end %>
<%= render :partial => "error_message" , :locals=>{:message_obj=>flash[:error_msgs],:style_class=>'err'} %>
<div class="container" style="width:900px;margin:1em auto;">
    <div style="font-size:1.2rem;background-color:#eee;padding:5px 10px;">掲示情報</div>
    <table border="0" cellpadding="0" cellspacing="0" class="inTbl">
    <tr>
        <th class="listTitle" width="15%"><%= Board.human_attribute_name(:subject) %></td>
        <td class="listL"><%= @comment.board.subject %></td>
    </tr>
    <tr>
        <th class="listTitle" width="15%">掲示期間</td>
        <td class="listL"><%= @comment.board.view_tarm_str("%Y/%m/%d %H:%M") %></td>
    </tr>
    <tr>
        <th class="listTitle" width="15%">本文</td>
        <td class="listL">
            <p><%= @comment.board.body1 %></p>
            <p><%= @comment.board.body2 %></p>
        </td>
    </tr>
    </table>
    <%= render :partial => "error_message" , :locals=>{:message_obj=>flash[:msg],:style_class=>'err'} %>
    <%= render :partial => "error_message" , :locals=>{:message_obj=>flash[:error_msgs],:style_class=>'err'} %>
</div>
<div class="container" style="width:900px;margin:1em auto;">
    <%= form_with model:@board_comment,url:{:controller=>"operator/board_comments",:action=>:update},:method=>:put,:id=>"inform",:local=> true do |form| %>
        <div style="font-size:1.2rem;background-color:#eee;padding:5px 10px;">コメント</div>
        <table border="0" cellpadding="0" cellspacing="0" class="inTbl">
            <tr width=>
                <%= content_tag :th,BoardComment.human_attribute_name(:comment_no),:width=>"15%" %>
                <%= content_tag :td,@comment.comment_no %>
            </tr>
            <tr>
                <%= content_tag :th,'投稿日時',:width=>"15%" %>
                <%= content_tag :td,@comment.created_at.strftime("%Y/%m/%d %H:%M") %>
            </tr>
            <tr>
                <%= content_tag :th,BoardComment.human_attribute_name(:comment),:width=>"15%" %>
                <%= content_tag :td,form.text_area(:comment,:type=>"text_area",:rows=>'5',:cols=>'50',:value=>@comment.comment) %>
            </tr>
        </table>
    <% end %>
    <%= form_with model:@board_comment,url:{:controller=>"operator/board_comments",:action=>:destroy},:method=>:delete,:id=>"delform",:local=> true do |form| %>
    <% end %>
    <div class='flex f-spacebetween'>
        <%= button_tag "変更する",:class=>"btn btn-update",:id=>"update-btn",:onclick=>"doUpdate();" %>
        <%= button_tag "削除する",:class=>"btn btn-destroy",:id=>"delete-btn",:onclick=>"doDestroy();" %>
    </div>
</div>
<%= render :partial => 'operator/back_to_top' %>
