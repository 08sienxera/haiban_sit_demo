<div id="link_box" class="links">
<% if back_links.blank? %>
  <%= submit_tag(:button, :value=>"閉じる",:onclick=>"window.close();",:type=>"button") %>
<% else %>
  <table><tr>
  <% back_links.each_with_index{|link,index| %>
    <%= content_tag("td","｜",:class=>"listC") if index > 0 %>
    <%= content_tag("td",link_to(link[:txt],link[:path]),:class=>"listC") %>
  <% } end %>
  </tr></table>
</div>