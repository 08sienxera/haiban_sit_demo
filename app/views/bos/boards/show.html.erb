<% content_for(:head){%>
<style type="text/css"><!--
.flex {display:flex;} 
table.comment_section {border-collapse: collapse;}
table.comment_section tr>*{text-align:left;padding:5px}
table.comment_section tr th{color:#333;border-top:1px solid #333;font-weight:600;}
table.comment_section tr th a{text-decoration:none;}
table.comment_section tr td{padding-left:1.2em;border-bottom:1px solid #333;}
table.comment_section tr td textarea {
    border: none;
    resize: none;
    outline: none;
    width: 100%;
}
div.button-container {display:flex;}
div.button-container.d-none {display:none;}
.submit-btn {
    cursor: pointer;
    padding: 10px;
    font-size: 1.3rem;
    display: block;
    margin: 2rem auto;
    width: 400px;
    border-radius: 10px;
}
#create-btn,#update-btn {background-color: lightgreen;}
#clear-btn {background-color: #f1a899;}
table.soloidline tr th {font-weight: normal;width: 15%;}
table.soloidline tr td {padding:10px;}

<% # コメント投稿フォームCSS %>
#commentFormBox {position: absolute;left: 50%;top: 80%;background-color: white;width: 80%;transform: translate(-50%, -50%);text-align: center;padding: 5px;border:3px solid green;box-shadow: 0px 0px 10px gray;}
#commentFormBox.deactive {display:none;}
#commentFormBox table,#commentFormBox table textarea{width:98%  }
span.msg{font-weight:bold;color:red;}
#file-link::before {
    content: 'ダウンロード';
    display: inline-block;
    border: solid 1px black;
    font-size: 0.8rem;
    margin-right: 16px;
    background-color: blanchedalmond;
    color: black;
    border-radius: 8px;
    padding: 1px 4px;
    position:relative;
    top:-3px;
}

--></style>
<%= javascript_tag do %>
    const confirmBoard = ()=>{
        event.preventDefault();
        const form = document.getElementsByName('confirmation-form')[0];
        fetch(form.action, {
            method: form.method,
            body: new FormData(form)
        }).then(response => {
            let statusCode = response.status;
            if (statusCode === 200) {
                let btn = document.getElementById('cofirm-btn');
                btn.classList.add('disabled');
                btn.setAttribute('disabled',true);
                btn.textContent='確認済みです';
            } else {
                alert('確認報告の更新に失敗しました (' + statusCode + ')');
            }
        }).catch(error => {
            alert('確認報告の更新に失敗しました: ' + error.message);
        });
    }
    const cancel = ()=>{
        let className = 'd-none';
        document.getElementById('buttons_at_create').classList.remove(className);
         document.getElementById('buttons_at_update').classList.add(className);
        
        document.getElementById('comment-input-box').value = null;
        let idFields = document.querySelectorAll("#board_comment_id");
        idFields.forEach((f)=>{f.value=null});
    };
    const setValueToComBox = (t)=>{
        let className = 'd-none';
        event.preventDefault();
        let commentId = t.id.substr(t.id.indexOf("_",0)+1);
        let idFields = document.querySelectorAll("#board_comment_id");
        idFields.forEach((f)=>{f.value=commentId});
        document.getElementById('comment-input-box').value = document.getElementById(`modComTxt_${commentId}`).value ;
        document.getElementById('buttons_at_create').classList.add(className);
        document.getElementById('buttons_at_update').classList.remove(className);
    };
    const doCreate = ()=>{
        let inputbox = document.getElementById('comment-input-box');
        let form = document.getElementById('createform');
        form.querySelector('#board_comment_body').value = inputbox.value
        form.submit();
        /* let form =  */
    };
    const doUpdate = ()=>{
        let inputbox = document.getElementById('comment-input-box');
        let form = document.getElementById('updateform');
        form.querySelector('#board_comment_body').value = inputbox.value
        form.submit();
    };
    const doDestroy = ()=>{
        let form = document.getElementById('deleteform');
        if(confirm("コメントを削除しますか？")){
            form.submit();
        }
    };

<% end } %>
<div id="field2" style="max-width:1500px">
<div class="listC">
    <%= render :partial => "error_message" , :locals=>{:message_obj=>flash[:error_msgs],:style_class=>'err'} %>
    <%= render :partial => "error_message" , :locals=>{:message_obj=>flash[:msg],:style_class=>'msg'} %>
</div>
<table style="width:100%;margin-top:20px;" class="soloidline">
    <% @boardInformation.each do |attribute| %>
        <tr>
            <%= content_tag :th,attribute[:head],:class=>"listTitle" %>
            <% if attribute[:key]=="body" %>
                <%= content_tag :td,:class=>""<<" #{attribute[:style_class]}" do %>
                    <%= content_tag :p,attribute[:text][0],:class=>"libr" %>
                        <%= img_previous(@board) %>
                    <%= content_tag :p,attribute[:text][1],:class=>"libr" %>
                <% end %>
                <% next %>
            <% end %>
            <%= content_tag :td,attribute[:text],:class=>""<<" #{attribute[:style_class]}" %>
        </tr>
    <% end %>
    <% if @board.has_file? %>
        <tr>
            <th class='listTitle'>添付ファイル</th>
            <td><%= file_download_links(@board) %></td>
        </tr>
    <% end %>

</table>
<% if @edit_permission %>
    <%= button_to("編集画面に移動する",{:controller=>@manage_controller,:action=>:edit,:id=>@board[:id]},{:method=>:get,:class=>"btn submit-btn"}) %>
<% else %>
    <%= form_tag({:controller=>"worker_common/board_targets",:action=>:update,:id=>@board_target.id},{:method=>:put,:name => 'confirmation-form'}) do %>
        <% if @board_target.confirmation_m_at.present? %>
            <%= button_tag("確認済みです",:id=>'cofirm-btn',:class=>'btn submit-btn disabled',:disabled=>true) %>
        <% else %>
            <%= button_tag("確認しました",:id=>'cofirm-btn',:class=>'btn submit-btn btn-update',:onclick=>"confirmBoard()") %>
        <% end %>

    <% end %>
<% end %>
<table style="width:100%;margin-top:20px;" class="comment_section">
    <% @board_comments.each do |comment| %>
        <tr id='comment_<%= comment[:id] %>'>
            <%= content_tag :th do %>
                <i class="fa-solid fa-comments"></i>
                <% if comment[:is_mine] %>
                    <%= link_to "#",:id=>"modComLi_#{comment[:id]}",:onclick=>"showCommentForm(#{comment[:id]});" do %>
                        <i class="fa-regular fa-pen-to-square"></i>
                    <% end %>
                <% end %>
                <%= comment[:poster] %>
            <% end %>
        </tr>
        <tr>
            <%= content_tag :td do %>
                <div id="board_comment_<%= comment[:id] %>">
                    <p class="libr"><span><%= comment[:body] %></span></p>
                </div>
            <% end %>
        </tr>
    <% end %>
</table>
<%= render :partial => 'manager/board_comment_form' , :locals=>{:dataline => @dataline} %>
<div class='button-container' id='buttons_at_create'>
    <%= button_tag "新規コメント",:id=>"create-btn",:class=>"submit-btn",:onclick=>"showCommentForm();" %>
</div>
<%= render :partial => 'links' , :locals=>{:back_links => @links} %>
